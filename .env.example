# =============================================================================
# LastLatentMAS — Experiment Config (.env)
# Chỉnh sửa file này để thay đổi cấu hình thay vì sửa command-line args.
# Dùng: bash run.sh  hoặc  python3 run.py  (run.py tự đọc file .env này)
# =============================================================================

# ---------------- Core experiment args ----------------
METHOD=latent_mas                 # baseline | text_mas | latent_mas | collect_only | collect_and_train_ae
MODEL_NAME=Qwen/Qwen3-0.6B        # Qwen/Qwen3-0.6B | Qwen/Qwen3-4B | Qwen/Qwen3-14B
TASK=gsm8k                        # gsm8k | aime2024 | aime2025 | gpqa | arc_easy | arc_challenge | mbppplus | humanevalplus | medqa
PROMPT=sequential                 # sequential | hierarchical
MAX_SAMPLES=-1                    # -1 = toàn bộ dataset
SPLIT=test

# ---------------- Generation args ----------------
MAX_NEW_TOKENS=4096
LATENT_STEPS=10
TEMPERATURE=0.6
TOP_P=0.95
GENERATE_BS=5
TEXT_MAS_CONTEXT_LENGTH=-1

# ---------------- Boolean flags (true/false) ----------------
THINK=false
LATENT_SPACE_REALIGN=false
ACCUMULATE_LATENT=false

# ---------------- vLLM / multi-GPU ----------------
USE_VLLM=false
ENABLE_PREFIX_CACHING=false
USE_SECOND_HF_MODEL=false
DEVICE=cuda
DEVICE2=cuda:1
TENSOR_PARALLEL_SIZE=1
GPU_MEMORY_UTILIZATION=0.8
DEVICE_MAP_AUTO=false

# ---------------- Query-Aware Autoencoder (AE) ----------------
# Chỉ dùng khi METHOD=collect_and_train_ae hoặc ae_checkpoint_dir có checkpoint.
AE_TARGET_LAYERS=-5,-4,-3,-2,-1   # Các layer index (signed) dùng cho AE, vd: -5,-4,-3,-2,-1
AE_BOTTLENECK_DIM=512             # Kích thước bottleneck Z (compressed representation)
AE_EPOCHS=150                     # Số epochs training mỗi layer
AE_BATCH_SIZE=256                 # Mini-batch size khi training AE
AE_LR=0.001                       # Learning rate cho AE optimizer (Adam)
AE_LAMBDA_SPARSE=0.01             # Trọng số L1 sparsity loss trên bottleneck
AE_LAMBDA_ATTN=0.1                # Trọng số binary-entropy loss trên attention gate
AE_NUM_HEADS=0                    # Kích thước hidden layer của FeatureGate MLP (0 = auto = hidden_dim//2)
AE_CHECKPOINT_DIR=                # Thư mục gốc lưu AE checkpoints (mặc định: ae_checkpoints/paired_hidden_state_cache/)
AE_LATENT_DATA_DIR=latent_data    # Thư mục lưu kết quả collect_only (mặc định: latent_data)
AE_COLLECT_SAMPLES=-1             # Số samples thu thập hidden states (-1 = toàn bộ dataset)
AE_NON_JUDGER_AGENTS=Planner,Critic,Refiner  # Tên agents được thu thập hidden states (loại trừ Judger)

# ---------------- WCT Space Alignment ----------------
# Ánh xạ hidden states từ layer_i space → last layer space trước khi realign.
# Chạy build_wct_params.py trước để tạo params, sau đó chỉ cần set path ở đây.
WCT_PARAMS_DIR=                    # Thư mục chứa wct_layer_*.npz (để trống = tắt WCT)

# ---------------- Logging / KV cache ----------------
SAVE_KV=false
KV_FLUSH_INTERVAL=30

# ---------------- Reproducibility ----------------
SEED=42
